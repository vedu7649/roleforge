import React, { useState, useEffect } from 'react';
import { Code, Share2, RefreshCw, Clock, ChevronRight } from 'lucide-react';
import { aiService } from '../services/aiService';

export default function VisibilityCard({ completedTasks = [], role = 'Developer' }) {
  const [taskSuggestions, setTaskSuggestions] = useState([
    {
      id: 1,
      title: 'Array Two Sum Problem',
      problemStatement: 'Given an array of integers, find two numbers that add up to a target value. Return their indices.',
      solution: 'Solved the Two Sum problem using a hash map approach for O(n) time complexity. Learned efficient problem-solving strategies.',
      difficulty: 'easy'
    },
    {
      id: 2,
      title: 'String Manipulation Challenge',
      problemStatement: 'Reverse a string in-place and detect palindromes. Handle edge cases efficiently.',
      solution: 'Completed string reversal and palindrome detection. Mastered two-pointer techniques.',
      difficulty: 'medium'
    },
    {
      id: 3,
      title: 'Tree Traversal Implementation',
      problemStatement: 'Implement DFS and BFS traversal for binary trees. Handle different node types.',
      solution: 'Built complete tree traversal system with recursive and iterative approaches. Deepened understanding of graph algorithms.',
      difficulty: 'medium'
    },
    {
      id: 4,
      title: 'Dynamic Programming Problem',
      problemStatement: 'Solve the longest common subsequence problem. Optimize for space and time.',
      solution: 'Implemented DP solution with memoization. Learned optimization techniques for complex problems.',
      difficulty: 'hard'
    }
  ]);

  const [currentIndex, setCurrentIndex] = useState(0);
  const [loading, setLoading] = useState(false);
  const [timeLeft, setTimeLeft] = useState(30 * 60); // 30 minutes in seconds
  const [isGenerating, setIsGenerating] = useState(false);

  const currentTask = taskSuggestions[currentIndex] || taskSuggestions[0];

  // Load AI-generated tasks on component mount
  useEffect(() => {
    const loadTasks = async () => {
      setIsGenerating(true);
      const tasks = await aiService.generateVisibilityTasks(completedTasks, role);
      setTaskSuggestions(tasks);
      setCurrentIndex(0);
      setIsGenerating(false);
    };
    loadTasks();
  }, [completedTasks, role]);

  // Auto-refresh timer
  useEffect(() => {
    const interval = setInterval(() => {
      setTimeLeft(prev => {
        if (prev <= 1) {
          // Auto-refresh tasks
          refreshSuggestions();
          return 30 * 60;
        }
        return prev - 1;
      });
    }, 1000);
    return () => clearInterval(interval);
  }, []);

  const formatTime = (seconds) => {
    const mins = Math.floor(seconds / 60);
    const secs = seconds % 60;
    return `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
  };

  const refreshSuggestions = async () => {
    setLoading(true);
    const tasks = await aiService.generateVisibilityTasks(completedTasks, role);
    setTaskSuggestions(tasks);
    setCurrentIndex(0);
    setTimeLeft(30 * 60);
    setLoading(false);
  };

  const nextTask = () => {
    setCurrentIndex((prev) => (prev + 1) % taskSuggestions.length);
  };

  const getDifficultyColor = (difficulty) => {
    switch(difficulty) {
      case 'easy': return '#10b981';
      case 'medium': return '#f59e0b';
      case 'hard': return '#ef4444';
      default: return 'var(--primary)';
    }
  };

  return (
    <div className="dashboard-card" style={{ marginTop: '1.5rem', opacity: isGenerating ? 0.6 : 1, transition: 'opacity 0.3s' }}>
      <div className="card-header" style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
        <div>
          <h3>🌟 Public Building (Weekly)</h3>
          <div style={{ display: 'flex', alignItems: 'center', gap: '0.5rem', fontSize: '0.8rem', color: 'var(--text-secondary)', marginTop: '0.25rem' }}>
            <Clock size={14} />
            {isGenerating ? 'Generating tasks...' : `Next refresh: ${formatTime(timeLeft)}`}
          </div>
        </div>
        <button
          type="button"
          className="btn btn-sm"
          onClick={refreshSuggestions}
          disabled={loading || isGenerating}
        >
          <RefreshCw size={16} style={{ animation: (loading || isGenerating) ? 'spin 1s linear infinite' : 'none' }} />
          Refresh
        </button>
      </div>

      {isGenerating ? (
        <div style={{ marginTop: '2rem', textAlign: 'center', padding: '2rem' }}>
          <div style={{ fontSize: '0.9rem', color: 'var(--text-secondary)' }}>
            ✨ Learning AI is analyzing your progress and generating personalized tasks...
          </div>
        </div>
      ) : (
        <div style={{ marginTop: '1.5rem' }}>
          {/* Task Navigation */}
          <div style={{ marginBottom: '1.5rem', padding: '0.75rem 1rem', background: 'rgba(var(--primary-rgb), 0.08)', borderRadius: '0.75rem', display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
          <span style={{ fontSize: '0.85rem', fontWeight: 600, color: 'var(--text-secondary)' }}>
            Task {currentIndex + 1} of {taskSuggestions.length}
          </span>
          <span 
            style={{ 
              fontSize: '0.75rem', 
              fontWeight: 700, 
              padding: '0.35rem 0.75rem',
              borderRadius: '20px',
              background: getDifficultyColor(currentTask.difficulty),
              color: 'white',
              textTransform: 'uppercase'
            }}
          >
            {currentTask.difficulty}
          </span>
        </div>

        {/* Problem Statement Section */}
        <div style={{ marginBottom: '1.75rem', padding: '1.25rem', background: 'var(--bg-hover)', borderRadius: '0.75rem', border: '1px solid var(--border)' }}>
          <h4 style={{ margin: '0 0 0.75rem 0', color: 'var(--text-primary)', fontSize: '1rem', fontWeight: 700 }}>
            {currentTask.title}
          </h4>
          <p style={{ margin: '0 0 1rem 0', fontSize: '0.95rem', color: 'var(--text-secondary)', lineHeight: 1.6 }}>
            <strong>Problem Statement:</strong>
          </p>
          <p style={{ margin: 0, fontSize: '0.9rem', color: 'var(--text-muted)', lineHeight: 1.6, fontStyle: 'italic' }}>
            {currentTask.problemStatement}
          </p>
        </div>

        {/* Solution Sharing Grid */}
        <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '1rem', marginBottom: '1.25rem' }}>
          {/* GitHub Section */}
          <div style={{ padding: '1.25rem', border: '1px solid rgba(15, 23, 42, 0.08)', borderRadius: '0.75rem', background: 'var(--bg-card)' }}>
            <div style={{ display: 'flex', alignItems: 'center', gap: '0.5rem', marginBottom: '0.75rem', color: '#333', fontSize: '0.85rem', fontWeight: 600 }}>
              <Code size={18} />
              GitHub Push
            </div>
            <p style={{ margin: '0 0 0.75rem 0', fontSize: '0.85rem', color: 'var(--text-secondary)', lineHeight: 1.5 }}>
              <strong>Solution to share:</strong>
            </p>
            <p style={{ margin: 0, fontSize: '0.85rem', color: 'var(--text-muted)', lineHeight: 1.5 }}>
              {currentTask.solution}
            </p>
            <button className="btn btn-outline" style={{ marginTop: '1rem', width: '100%', fontSize: '0.85rem' }}>
              Push to GitHub
            </button>
          </div>

          {/* LinkedIn Section */}
          <div style={{ padding: '1.25rem', border: '1px solid rgba(15, 23, 42, 0.08)', borderRadius: '0.75rem', background: 'var(--bg-card)' }}>
            <div style={{ display: 'flex', alignItems: 'center', gap: '0.5rem', marginBottom: '0.75rem', color: '#0A66C2', fontSize: '0.85rem', fontWeight: 600 }}>
              <Share2 size={18} />
              LinkedIn Post
            </div>
            <p style={{ margin: '0 0 0.75rem 0', fontSize: '0.85rem', color: 'var(--text-secondary)', lineHeight: 1.5 }}>
              <strong>Achievement to celebrate:</strong>
            </p>
            <p style={{ margin: 0, fontSize: '0.85rem', color: 'var(--text-muted)', lineHeight: 1.5 }}>
              "Just solved: {currentTask.title}. {currentTask.solution} #coding #dsa #learning"
            </p>
            <button className="btn btn-outline" style={{ marginTop: '1rem', width: '100%', fontSize: '0.85rem' }}>
              Copy to Clipboard
            </button>
          </div>
        </div>

        {/* Next Button for Difficulty */}
        <div style={{ display: 'flex', justifyContent: 'center' }}>
          <button
            type="button"
            className="btn btn-primary"
            onClick={nextTask}
            style={{ gap: '0.5rem' }}
          >
            This is too hard, show me next <ChevronRight size={16} />
          </button>
        </div>
      </div>
    </div>
  );
